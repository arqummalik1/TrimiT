# Copy to .env.local for local dev. In Vercel, set these under Project → Settings → Environment Variables.

# API origin only (no /api/v1 path)
REACT_APP_BACKEND_URL=https://trimit-az5h.onrender.com

# Supabase (same project as mobile/backend)
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_anon_key

# After first Vercel deploy, set to your live URL (e.g. https://trimit-xxxx.vercel.app)
# Used in Play Console docs and optional absolute links.
REACT_APP_PUBLIC_SITE_URL=

# Optional
REACT_APP_RAZORPAY_KEY_ID=
REACT_APP_GOOGLE_MAPS_API_KEY=
