# Copy to .env.local for local dev. In Vercel, set these under Project → Settings → Environment Variables.

# API origin only (no /api/v1 path)
REACT_APP_BACKEND_URL=https://trimit-az5h.onrender.com

# Supabase (same project as mobile/backend)
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_anon_key

# Live Vercel site (Play Console privacy/contact URLs)
REACT_APP_PUBLIC_SITE_URL=https://trimit.online

# Android download (default: Google Drive APK folder). Header + footer use this until Play Store is live.
REACT_APP_DOWNLOAD_APP_URL=https://drive.google.com/drive/u/0/folders/1jZg_nTVk_tnIh1jPm-rG8ABkeINqrsEW

# Optional — set when app is on Play Console (footer then shows “Google Play” and uses this URL)
# REACT_APP_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.trimit.app

# Backend (Render): PUBLIC_SITE_URL — password-reset email redirect target

# Google Search Console — only if you chose HTML tag verification (not needed for DNS/TXT on Hostinger)
# REACT_APP_GOOGLE_SITE_VERIFICATION=your_verification_token_here

# Optional — Google Analytics 4 (separate from Search Console; set if you use GA4)
# REACT_APP_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional
REACT_APP_RAZORPAY_KEY_ID=
REACT_APP_GOOGLE_MAPS_API_KEY=
