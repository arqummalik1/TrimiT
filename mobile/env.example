# Copy to .env — required for local APK/AAB builds (.env is gitignored; not sent to EAS cloud)

EXPO_PUBLIC_API_URL=https://trimit-az5h.onrender.com
EXPO_PUBLIC_PUBLIC_SITE_URL=https://trimit.online

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_android_key
# Optional iOS-only key (online.trimit.app). Empty = reuse Android/shared key above.
EXPO_PUBLIC_GOOGLE_MAPS_IOS_API_KEY=

# Google Sign-In
# WEB client ID = the Google Cloud "Web application" OAuth client ID. REQUIRED —
#   Android native sign-in uses it to request an idToken, and Supabase must have
#   this SAME web client ID configured under Auth → Providers → Google.
# IOS client ID = only needed if you ship an iOS build.
# Android also needs your app's SHA-1 registered on an "Android" OAuth client in
#   Google Cloud (upload key + Play App Signing key). No value goes in .env for
#   that — it is matched by package name + SHA-1 on Google's side.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_ENABLE_ONLINE_PAY=false
SENTRY_DISABLE_AUTO_UPLOAD=true
